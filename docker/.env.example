# Copy this file to docker/.env and edit for your environment.

# Nextcloud AIO mastercontainer
APACHE_PORT=11000
APACHE_IP_BINDING=127.0.0.1

# Host path exposed to Nextcloud AIO for local external storage.
# In the current Windows + Docker Desktop + WSL2 environment, D:\home is visible as /mnt/d/home.
NEXTCLOUD_MOUNT=/mnt/d/home

# AIO admin UI port on localhost.
AIO_ADMIN_PORT=8080

# Tailscale FQDN used as the Nextcloud domain in AIO.
# Do not put a private tailnet name in committed files.
NEXTCLOUD_HOST=<machine-name>.<tailnet>.ts.net
